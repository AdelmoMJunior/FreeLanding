# Public Supabase values used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key used only by src/lib/supabase/admin.ts.
# Never expose this in client components or NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional Google Analytics measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=

# Optional. Set to true only when your deployment proxy overwrites client IP headers.
LEAD_FORM_TRUST_PROXY_HEADERS=false

# Optional Resend integration for lead notification emails.
# Both values are required when lead notifications are enabled in the admin panel.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
